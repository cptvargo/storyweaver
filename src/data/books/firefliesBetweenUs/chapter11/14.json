{
  "page": 14,
  "chapter": 11,
  "chapterTitle": "On Purpose",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    { "type": "narration", "content": "Savannah found out by text at eleven-fifteen that same night." },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "he asked me" },
    { "type": "message", "platform": "SMS", "sender": "Savannah", "content": "DAISY MAY JONES" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "I said yes" },
    { "type": "message", "platform": "SMS", "sender": "Savannah", "content": "I KNOW YOU SAID YES I HAVE BEEN WAITING FOR THIS SINCE WE WERE FOURTEEN" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "you were in the video" },
    { "type": "message", "platform": "SMS", "sender": "Savannah", "content": "I was in SOCKS Daisy I was in SOCKS" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "you looked beautiful" },
    { "type": "message", "platform": "SMS", "sender": "Savannah", "content": "I was crying in socks on my front porch" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "still beautiful. call me tomorrow. I need to sleep but I'm too happy to sleep" },
    { "type": "message", "platform": "SMS", "sender": "Savannah", "content": "same. I love you. I'm so happy for you" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "I love you too" },
    { "type": "narration", "content": "Mrs. Jones called at seven the next morning — which was six in Minnesota. Daisy picked up anyway." },
    { "type": "dialogue", "speaker": "Mrs. Jones", "content": "He told you." },
    { "type": "dialogue", "speaker": "Daisy", "content": "He asked me." },
    { "type": "dialogue", "speaker": "Mrs. Jones", "content": "And." },
    { "type": "dialogue", "speaker": "Daisy", "content": "Mom." },
    { "type": "dialogue", "speaker": "Mrs. Jones", "content": "I just want to hear you say it." },
    { "type": "dialogue", "speaker": "Daisy", "content": "I said yes." },
    { "type": "dialogue", "speaker": "Daisy", "content": "Mom. Mom, don't cry." },
    { "type": "dialogue", "speaker": "Mrs. Jones", "content": "I am absolutely going to cry. He came to my door, Daisy. He came home and knocked on my door just to put me in that film. That boy —" },
    { "type": "dialogue", "speaker": "Daisy", "content": "I know." },
    { "type": "dialogue", "speaker": "Mrs. Jones", "content": "You keep him." },
    { "type": "dialogue", "speaker": "Daisy", "content": "That's the plan." }
  ]
}
