{
  "page": 19,
  "chapter": 12,
  "chapterTitle": "The Field",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    {
      "type": "narration",
      "content": "The banquet was four hours and nobody wanted it to end."
    },
    {
      "type": "dialogue",
      "speaker": "Meilin",
      "content": "Longevity noodles. You eat the whole noodle without cutting it. It brings long life."
    },
    {
      "type": "dialogue",
      "speaker": "Marcus",
      "content": "Without cutting it."
    },
    {
      "type": "dialogue",
      "speaker": "Meilin",
      "content": "Do not bite."
    },
    {
      "type": "narration",
      "content": "Marcus looked at the noodle. The noodle was very long. He attempted it with great sincerity."
    },
    {
      "type": "dialogue",
      "speaker": "Savannah",
      "content": "Marcus."
    },
    {
      "type": "dialogue",
      "speaker": "Marcus",
      "content": "I've got it."
    },
    {
      "type": "dialogue",
      "speaker": "Savannah",
      "content": "You do not have it."
    },
    {
      "type": "dialogue",
      "speaker": "Marcus",
      "content": "I'm committed."
    },
    {
      "type": "narration",
      "content": "The table erupted. Meilin's uncle appeared to find this deeply charming."
    },
    {
      "type": "narration",
      "content": "The toasts came. Eli stood."
    },
    {
      "type": "dialogue",
      "speaker": "Eli",
      "content": "I have been learning Mandarin for two years. I want everyone here to know I have been trying very hard. I have also been failing very consistently. Meilin tells me my tones are — and I quote — creative."
    },
    {
      "type": "narration",
      "content": "He turned to her parents and raised his glass."
    },
    {
      "type": "dialogue",
      "speaker": "Eli",
      "content": "干杯。",
      "translation": "Cheers."
    },
    {
      "type": "narration",
      "content": "Tones still wrong. The room cheered anyway."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "Kit. You're filming it."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "I didn't even realize I —"
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "Film it."
    },
    {
      "type": "narration",
      "content": "He filmed it."
    }
  ]
}
