{
  "page": 18,
  "chapter": 12,
  "chapterTitle": "The Field",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    {
      "type": "narration",
      "content": "Meilin's mother came to her daughter when the hall had found its voice again."
    },
    {
      "type": "narration",
      "content": "She cupped her face in both hands. Said one thing."
    },
    {
      "type": "dialogue",
      "speaker": "Meilin's Mother",
      "content": "你找到了一个好人。",
      "translation": "You found a good person."
    },
    {
      "type": "narration",
      "content": "Meilin's composure — steady through the whole ceremony — came undone in one breath."
    },
    {
      "type": "dialogue",
      "speaker": "Savannah",
      "content": "I'm not going to make it."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "Don't you dare."
    },
    {
      "type": "dialogue",
      "speaker": "Savannah",
      "content": "I'm trying."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "Try harder."
    },
    {
      "type": "dialogue",
      "speaker": "Savannah",
      "content": "I've known Eli for fifteen years."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "I know. Me too."
    },
    {
      "type": "narration",
      "content": "Meilin's mother turned to Eli."
    },
    {
      "type": "dialogue",
      "speaker": "Meilin's Mother",
      "content": "Take care of my daughter."
    },
    {
      "type": "dialogue",
      "speaker": "Eli",
      "content": "Every day. I promise."
    },
    {
      "type": "narration",
      "content": "She nodded once. Touched his arm. Returned to her seat."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "Kit."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "Yeah."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "I need a minute."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "Take it."
    }
  ]
}
