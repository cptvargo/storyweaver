  "chapterTitle": "The Field",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    {
      "type": "narrative",
      "content": "Nine weeks. Nobody knew but them."
    },
    {
      "type": "narrative",
      "content": "She found his copy of What to Expect on the nightstand one morning with a sticky note on the names chapter."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "You highlighted Henry."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "It's a solid name."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "It is a solid name."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "What do you have."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "Mae. If it's a girl."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "After Grandma Mae."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "After Grandma Mae."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "Mae Jenkins."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "Mae Jenkins."
    },
    {
      "type": "narrative",
      "content": "He looked at the ceiling."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "What if it's a boy and he has your stubbornness."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "Then he'll figure things out."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "Eventually."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "Eventually is fine."
    },
    {
      "type": "narrative",
      "content": "She rolled toward him. He covered her hand with his."
    },
    {
      "type": "dialogue",
      "speaker": "Daisy",
      "content": "I'm happy."
    },
    {
      "type": "dialogue",
      "speaker": "Kit",
      "content": "Me too."
    },
    {
      "type": "narrative",
      "content": "The city moved outside the window. Just the two of them and the thing growing quietly between them, not yet named, not yet real to anyone but them."
    }
  ]
}
