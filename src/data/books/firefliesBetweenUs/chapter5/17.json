{
  "page": 17,
  "chapter": 5,
  "chapterTitle": "Offline",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    { "type": "narration", "content": "She was at her locker. She saw him coming and he watched her decide not to have somewhere to be." },
    { "type": "dialogue", "speaker": "Kit", "content": "Can I talk to you." },
    { "type": "dialogue", "speaker": "Daisy", "content": "You're already talking." },
    { "type": "dialogue", "speaker": "Kit", "content": "I should have told you. Before you heard it from someone else." },
    { "type": "dialogue", "speaker": "Daisy", "content": "Yeah." },
    { "type": "dialogue", "speaker": "Kit", "content": "I was going to. I just—" },
    { "type": "dialogue", "speaker": "Daisy", "content": "Kit." },
    { "type": "dialogue", "speaker": "Kit", "content": "I know. I know I messed up." },
    { "type": "narration", "content": "She looked at him." },
    { "type": "dialogue", "speaker": "Daisy", "content": "It's not about Brooke." },
    { "type": "dialogue", "speaker": "Kit", "content": "I know." },
    { "type": "dialogue", "speaker": "Daisy", "content": "You knew what that place was." },
    { "type": "narration", "content": "He didn't say anything. She was right." },
    { "type": "dialogue", "speaker": "Kit", "content": "Daisy—" },
    { "type": "dialogue", "speaker": "Daisy", "content": "I'm not angry at you." },
    { "type": "dialogue", "speaker": "Kit", "content": "You should be." },
    { "type": "dialogue", "speaker": "Daisy", "content": "Probably." }
  ]
}
