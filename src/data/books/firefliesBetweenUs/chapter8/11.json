{
  "page": 11,
  "chapter": 8,
  "chapterTitle": "Before August",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    { "type": "narration", "content": "That night. Her room. She opened AIM." },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "you there" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "always. what happened" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "i told kit about the song" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "DAISY." },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "i know" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "what happened what did he say" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "he said it wasnt just a song" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "obviously" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "he told me about seeing me and ryan kiss. in the hall. he saw it and didn't say anything" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "oh no" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "and I told him about brooke. the water tower. when you told me I was devastated but tried to keep my composure" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "daisy i always knew that. you went so quiet when i told you" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "we talked about the dance too. the almost" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "ok and then" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "he asked me to prom" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "." },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "as in. as his date." },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "yeah" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "and you said" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "yeah" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "I have been waiting for this since seventh grade" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "savannah" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "I HAVE BEEN" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "we're still going to different states in august" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "i know that" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "so nothing is solved" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "daisy. you've been in love with this boy since we were twelve. just let it be a good thing for five minutes" },
    { "type": "narration", "content": "She stared at the screen. Then she closed the laptop and lay back on her bed and looked at the ceiling and let it be a good thing." }
  ]
}
