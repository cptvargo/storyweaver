{
  "page": 14,
  "chapter": 8,
  "chapterTitle": "Before August",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    { "type": "narration", "content": "Prom was a Saturday in April. She texted him at noon." },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "savannah is doing my hair. this is a lot" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "good lot or bad lot" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "good i think. nervous" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "don't be" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "easy for you to say" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "i'll be there at 6" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "ok" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "kit" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "yeah" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "i'm glad you asked" },
    { "type": "narration", "content": "He stared at the screen. Then he put the phone down and went and stood in front of his closet." },
    { "type": "narration", "content": "His mom appeared in the doorway. He hadn't heard her come up." },
    { "type": "dialogue", "speaker": "Kit's Mom", "content": "New shirt?" },
    { "type": "dialogue", "speaker": "Kit", "content": "Thought I'd try something different." },
    { "type": "narration", "content": "She looked at the grey button-down he was holding. Then at him." },
    { "type": "dialogue", "speaker": "Kit's Mom", "content": "Different occasion." },
    { "type": "dialogue", "speaker": "Kit", "content": "Yeah." },
    { "type": "dialogue", "speaker": "Kit's Mom", "content": "You nervous?" },
    { "type": "dialogue", "speaker": "Kit", "content": "A little." },
    { "type": "dialogue", "speaker": "Kit's Mom", "content": "Good." },
    { "type": "dialogue", "speaker": "Kit", "content": "That's supposed to make me feel better?" },
    { "type": "dialogue", "speaker": "Kit's Mom", "content": "Nervous means it matters. You've been pretending this doesn't matter for a very long time." },
    { "type": "narration", "content": "He looked at the shirt." },
    { "type": "dialogue", "speaker": "Kit", "content": "Mom —" },
    { "type": "dialogue", "speaker": "Kit's Mom", "content": "I know. I know. Go." },
    { "type": "narration", "content": "She squeezed his arm once on the way out. He put on the shirt. Checked the mirror. Headed for the door." }
  ]
}
