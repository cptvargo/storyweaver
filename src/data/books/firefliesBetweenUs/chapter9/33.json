{
  "page": 33,
  "chapter": 9,
  "chapterTitle": "The Distance",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    { "type": "narration", "content": "Spring semester found its rhythm faster than fall. They knew the schools now, knew the routines, knew which nights to call and which nights the other was buried in work and a text was enough." },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "screening tonight. nervous" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "the film?" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "professor is showing it in the senior capstone class. as an example of something" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "kit. that's huge" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "or it's an example of what not to do" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "it's not. call me after" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "yeah" },
    { "type": "narration", "content": "He called at ten. She picked up before the first ring finished." },
    { "type": "dialogue", "speaker": "Daisy", "content": "Tell me." },
    { "type": "dialogue", "speaker": "Kit", "content": "They liked it." },
    { "type": "dialogue", "speaker": "Daisy", "content": "Kit." },
    { "type": "dialogue", "speaker": "Kit", "content": "The professor said it had — she said it had emotional architecture. That it understood what it was about." },
    { "type": "dialogue", "speaker": "Daisy", "content": "She's right." },
    { "type": "dialogue", "speaker": "Kit", "content": "You still haven't seen it." },
    { "type": "dialogue", "speaker": "Daisy", "content": "I don't have to. I know what it's about." },
    { "type": "narration", "content": "He went quiet for a second." },
    { "type": "dialogue", "speaker": "Kit", "content": "Yeah." },
    { "type": "dialogue", "speaker": "Daisy", "content": "I'm proud of you." },
    { "type": "dialogue", "speaker": "Kit", "content": "You keep saying that." },
    { "type": "dialogue", "speaker": "Daisy", "content": "I'll keep meaning it." },
    { "type": "narration", "content": "February went. March. The distance was still real." },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "what are you doing for 4th of july" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "coming home. eli mentioned something" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "good" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "you'll be home?" },
    { "type": "message", "platform": "SMS", "sender": "Daisy", "content": "wouldn't miss it" }
  ]
}
