  "chapterTitle": "Somebody",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    { "type": "narration", "content": "The problem with Ryan Callaway was that there was no problem with Ryan Callaway." },
    { "type": "narration", "content": "Kit had spent a week waiting for one. But Ryan was thoughtful and funny and held doors open and actually listened when Daisy talked." },
    { "type": "narration", "content": "Eli pulled him aside after school on a Tuesday." },
    { "type": "dialogue", "speaker": "Eli", "content": "You've met Ryan." },
    { "type": "dialogue", "speaker": "Kit", "content": "Yeah." },
    { "type": "dialogue", "speaker": "Eli", "content": "And?" },
    { "type": "dialogue", "speaker": "Kit", "content": "And what." },
    { "type": "dialogue", "speaker": "Eli", "content": "And what do you think." },
    { "type": "dialogue", "speaker": "Kit", "content": "He seems fine." },
    { "type": "dialogue", "speaker": "Eli", "content": "He seems fine." },
    { "type": "dialogue", "speaker": "Kit", "content": "What do you want me to say?" },
    { "type": "dialogue", "speaker": "Eli", "content": "I want you to say what you actually think." },
    { "type": "dialogue", "speaker": "Kit", "content": "He seems fine, Eli." },
    { "type": "narration", "content": "Eli looked at him." },
    { "type": "dialogue", "speaker": "Eli", "content": "Okay." },
    { "type": "narration", "content": "He dropped it." }
  ]
}
