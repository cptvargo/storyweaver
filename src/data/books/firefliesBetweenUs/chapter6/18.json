{
  "page": 18,
  "chapter": 6,
  "chapterTitle": "Somebody",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    { "type": "narration", "content": "May. End of freshman year." },
    { "type": "narration", "content": "Things with Ryan were still going. Kit had stopped counting the weeks." },
    { "type": "narration", "content": "On the last Friday of the year, after school, Daisy found him at his locker." },
    { "type": "dialogue", "speaker": "Daisy", "content": "Walk home?" },
    { "type": "dialogue", "speaker": "Kit", "content": "Yeah." },
    { "type": "narration", "content": "They got their bikes and rode in the easy way they'd been riding since they were eight — Daisy taking the corner wide, Kit on the inside — and for the length of the ride it was just them, the year and the warm afternoon and the smell of spring going into summer." },
    { "type": "dialogue", "speaker": "Daisy", "content": "Good year?" },
    { "type": "dialogue", "speaker": "Kit", "content": "Parts of it." },
    { "type": "dialogue", "speaker": "Daisy", "content": "Which parts." },
    { "type": "dialogue", "speaker": "Kit", "content": "This part. Right now." },
    { "type": "narration", "content": "She looked at him sideways." },
    { "type": "dialogue", "speaker": "Daisy", "content": "You're getting sentimental." },
    { "type": "dialogue", "speaker": "Kit", "content": "I'm being honest." },
    { "type": "narration", "content": "She didn't answer. They rode on." },
    { "type": "internalThought", "speaker": "Kit", "content": "Sophomore year. I have time." }
  ]
}
