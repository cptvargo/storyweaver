{
  "page": 25,
  "chapter": 6,
  "chapterTitle": "Somebody",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "what do you think ryan would feel. if he knew" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "about the song or about you" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "both" },
    { "type": "narration", "content": "Savannah took a moment." },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "i think he'd be hurt" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "he pays attention to you daisy. like really pays attention. he'd feel it" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "i know" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "that's what makes this so hard" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "do you still want to be with him" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "i don't know" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "i'm not faking it with him. i actually like him. i want you to know that" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "i know you do" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "but" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "yeah" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "what does that make me" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "it makes you human" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "you can't help what's been there this whole time" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "that doesn't feel like enough" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "i know it doesn't" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "but you don't have to figure all of it out tonight" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "it doesn't feel like something i can just stop thinking about" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "i know. i'm not saying stop thinking about it. i'm just saying breathe." },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "get some sleep. i'm here tomorrow" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "okay" },
    { "type": "message", "platform": "AIM", "sender": "daisy_mjones", "content": "thank you" },
    { "type": "message", "platform": "AIM", "sender": "savannah_b", "content": "always" },
    { "type": "narration", "content": "She closed the chat. Sat in the dark." },
    { "type": "narration", "content": "Sophomore year was twelve weeks away. Ryan's goodnight text was still on her phone. Kit's song was still on his profile." },
    { "type": "narration", "content": "She closed the laptop. Lay back in the dark." },
    { "type": "narration", "content": "She didn't sleep for a long time." }
  ]
}
