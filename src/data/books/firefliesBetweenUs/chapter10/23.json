{
  "page": 23,
  "chapter": 10,
  "chapterTitle": "This Kind of Night",
  "bookId": "firefliesBetweenUs",
  "blocks": [
    { "type": "narration", "content": "He got home and sat on his bed in the dark for a while. His mom was asleep. The house was quiet." },
    { "type": "narration", "content": "His phone buzzed." },
    { "type": "message", "platform": "SMS", "sender": "Eli", "content": "I need you to know. Warm white. I chose warm white for the lanterns specifically. Neutral white is too harsh for emotional moments. I did the research." },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "Eli." },
    { "type": "message", "platform": "SMS", "sender": "Eli", "content": "Lighting matters." },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "thank you for tonight" },
    { "type": "message", "platform": "SMS", "sender": "Eli", "content": "yeah man" },
    { "type": "message", "platform": "SMS", "sender": "Eli", "content": "she's been waiting on you to figure it out for a long time. you both have" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "I know" },
    { "type": "message", "platform": "SMS", "sender": "Eli", "content": "you good?" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "yeah" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "really good" },
    { "type": "message", "platform": "SMS", "sender": "Eli", "content": "good. goodnight man" },
    { "type": "message", "platform": "SMS", "sender": "Kit", "content": "goodnight eli" },
    { "type": "narration", "content": "He set his phone on the nightstand. Outside his window, Millhaven was completely still. Down the block, in the house he'd known his whole life, there was a light still on." }
  ]
}
