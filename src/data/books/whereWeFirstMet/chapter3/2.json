{
  "page": 2,
  "chapter": 3,
  "chapterTitle": "Choosing Tomorrow",
  "bookId": "whereWeFirstMet",
  "pov": "Cassandra",
  "blocks": [
    { "type": "narration", "content": "Cassandra didn't go back inside right away." },
    { "type": "narration", "content": "The arcade door closed behind her with a soft chime, but she stayed just outside for a moment, one hand resting lightly against the glass." },
    { "type": "narration", "content": "Inside, the machines kept glowing." },
    { "type": "narration", "content": "Lights flickering." },
    { "type": "narration", "content": "Sounds overlapping." },
    { "type": "narration", "content": "Life continuing in that loud, careless way it always did." },
    { "type": "narration", "content": "But out here—" },
    { "type": "narration", "content": "It was quieter." },
    { "type": "narration", "content": "Cassandra adjusted Harold under her arm, pressing him slightly closer without realizing she was doing it." },
    { "type": "narration", "content": "Her fingers traced the edge of the worn stitching." },
    { "type": "narration", "content": "Soft." },
    { "type": "narration", "content": "Simple." },
    { "type": "narration", "content": "Given." },
    { "type": "narration", "content": "She exhaled slowly." },
    { "type": "narration", "content": "Her chest tightened—" },
    { "type": "narration", "content": "just slightly." },
    { "type": "narration", "content": "Not enough to stop her." },
    { "type": "narration", "content": "Not enough to show." },
    { "type": "narration", "content": "Enough to remind." },
    { "type": "narration", "content": "Cassandra closed her eyes for a second." },
    { "type": "internalThought", "character": "Cassandra", "content": "Don't ruin this." },
    { "type": "narration", "content": "The words came quietly, but they carried weight." },
    { "type": "narration", "content": "Not fear exactly." },
    { "type": "narration", "content": "Something more careful than that." },
    { "type": "narration", "content": "She opened her eyes again and looked out toward the street." },
    { "type": "narration", "content": "Ethan was already gone." },
    { "type": "narration", "content": "Of course he was." },
    { "type": "narration", "content": "He wasn't the kind of person who lingered in doorways or waited to see if someone would turn back again." },
    { "type": "narration", "content": "He moved forward." },
    { "type": "narration", "content": "Steady." },
    { "type": "narration", "content": "Quiet." },
    { "type": "narration", "content": "Intentional in ways he probably didn't even realize yet." },
    { "type": "narration", "content": "Cassandra smiled faintly." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Tomorrow." },
    { "type": "narration", "content": "The word felt dangerous." },
    { "type": "narration", "content": "Not because it was uncertain—" },
    { "type": "narration", "content": "but because it was possible." },
    { "type": "narration", "content": "She pushed the door open again and stepped back inside." },
    { "type": "narration", "content": "Lena looked up immediately." },
    { "type": "narration", "content": "Of course she did." },
    { "type": "narration", "content": "Cassandra didn't say anything." },
    { "type": "narration", "content": "She just walked past her, heading toward the back room, Harold still tucked under her arm like something she wasn't ready to put down yet." },
    { "type": "dialogue", "speaker": "Lena", "content": "Hey." },
    { "type": "narration", "content": "Lena called softly." },
    { "type": "narration", "content": "Cassandra paused, but didn't turn." },
    { "type": "dialogue", "speaker": "Lena", "content": "You okay?" },
    { "type": "narration", "content": "Cassandra considered the question." },
    { "type": "narration", "content": "Then answered honestly." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I don't know yet." }
  ]
}
