{
  "chapterIndex": 3,
  "pageIndex": 11,
  "blocks": [
    {
      "type": "narration",
      "content": "They didn’t leave the gallery right away."
    },
    {
      "type": "narration",
      "content": "There was a bench near the back wall."
    },
    {
      "type": "narration",
      "content": "Cassandra sat first."
    },
    {
      "type": "narration",
      "content": "Ethan followed."
    },
    {
      "type": "narration",
      "content": "Closer than before."
    },
    {
      "type": "narration",
      "content": "Not by accident."
    },
    {
      "type": "narration",
      "content": "Not completely."
    },
    {
      "type": "narration",
      "content": "The space between them felt smaller now."
    },
    {
      "type": "narration",
      "content": "More intentional."
    },
    {
      "type": "narration",
      "content": "Cassandra leaned back slightly, her shoulder pressing gently into his."
    },
    {
      "type": "narration",
      "content": "He stilled for a second—"
    },
    {
      "type": "narration",
      "content": "just a second."
    },
    {
      "type": "narration",
      "content": "Then relaxed into it."
    },
    {
      "type": "narration",
      "content": "The contact stayed."
    },
    {
      "type": "narration",
      "content": "Neither of them acknowledged it."
    },
    {
      "type": "narration",
      "content": "Which made it matter more."
    },
    {
      "type": "dialogue",
      "character": "Ethan",
      "content": "Do you always do this?"
    },
    {
      "type": "dialogue",
      "character": "Cassandra",
      "content": "Do what?"
    },
    {
      "type": "dialogue",
      "character": "Ethan",
      "content": "Let a day become something else."
    },
    {
      "type": "narration",
      "content": "Cassandra smiled faintly."
    },
    {
      "type": "dialogue",
      "character": "Cassandra",
      "content": "I think days already are something else."
    },
    {
      "type": "dialogue",
      "character": "Ethan",
      "content": "That doesn’t answer the question."
    },
    {
      "type": "dialogue",
      "character": "Cassandra",
      "content": "It kind of does."
    },
    {
      "type": "narration",
      "content": "Ethan looked at her."
    },
    {
      "type": "narration",
      "content": "She was staring forward, but her voice had softened."
    },
    {
      "type": "narration",
      "content": "Like she wasn’t talking about the day anymore."
    },
    {
      "type": "dialogue",
      "character": "Cassandra",
      "content": "Most people just don’t notice."
    },
    {
      "type": "narration",
      "content": "Ethan nodded slightly."
    },
    {
      "type": "dialogue",
      "character": "Ethan",
      "content": "I think I’m starting to."
    },
    {
      "type": "narration",
      "content": "Cassandra turned her head just enough to look at him."
    },
    {
      "type": "dialogue",
      "character": "Cassandra",
      "content": "You are."
    },
    {
      "type": "narration",
      "content": "For a moment—"
    },
    {
      "type": "narration",
      "content": "nothing else existed."
    },
    {
      "type": "narration",
      "content": "Not the gallery."
    },
    {
      "type": "narration",
      "content": "Not the city."
    },
    {
      "type": "narration",
      "content": "Not the quiet weight of things they hadn’t said yet."
    },
    {
      "type": "narration",
      "content": "Just that."
    }
  ]
}