{
  "page": 3,
  "chapter": 3,
  "chapterTitle": "Choosing Tomorrow",
  "bookId": "whereWeFirstMet",
  "pov": "Ethan",
  "blocks": [
    { "type": "narration", "content": "Ethan sat on the edge of his bed, phone in hand." },
    { "type": "narration", "content": "He had been sitting there for at least ten minutes." },
    { "type": "narration", "content": "Maybe more." },
    { "type": "narration", "content": "It was hard to tell." },
    { "type": "narration", "content": "Time felt different when your mind kept circling the same thought without landing anywhere." },
    { "type": "narration", "content": "The room around him was quiet." },
    { "type": "narration", "content": "Comfortably quiet." },
    { "type": "narration", "content": "The kind of quiet he had built for himself over the years." },
    { "type": "narration", "content": "No raised voices." },
    { "type": "narration", "content": "No tension hiding in the walls." },
    { "type": "narration", "content": "Just space." },
    { "type": "narration", "content": "His sketchbook sat on the desk across from him, still open to the last page he had worked on." },
    { "type": "narration", "content": "The fountain." },
    { "type": "narration", "content": "Of course it was the fountain." },
    { "type": "narration", "content": "But now—" },
    { "type": "narration", "content": "there was more." },
    { "type": "narration", "content": "Not detail." },
    { "type": "narration", "content": "Not fully." },
    { "type": "narration", "content": "Just the suggestion of something standing near it." },
    { "type": "narration", "content": "He hadn't erased it this time." },
    { "type": "narration", "content": "Ethan looked down at his phone again." },
    { "type": "narration", "content": "The message box was open." },
    { "type": "narration", "content": "Empty." },
    { "type": "narration", "content": "Then—" },
    { "type": "narration", "content": "He typed:" },
    { "type": "internalThought", "character": "Ethan", "content": "Bro…." },
    { "type": "narration", "content": "He stopped." },
    { "type": "narration", "content": "Stared at it." },
    { "type": "narration", "content": "Deleted it." },
    { "type": "narration", "content": "Typed again." },
    { "type": "internalThought", "character": "Ethan", "content": "I met someone." },
    { "type": "narration", "content": "That looked worse somehow." },
    { "type": "narration", "content": "Too serious." },
    { "type": "narration", "content": "Too real." },
    { "type": "narration", "content": "He leaned back slightly, pressing his free hand against his forehead." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Why is this hard?" },
    { "type": "narration", "content": "he muttered." },
    { "type": "narration", "content": "Because it mattered." },
    { "type": "narration", "content": "That was the problem." },
    { "type": "narration", "content": "If it didn't matter, he wouldn't be thinking about it this much." },
    { "type": "narration", "content": "He wouldn't be replaying conversations." },
    { "type": "narration", "content": "Wouldn't be noticing the way she said things." },
    { "type": "narration", "content": "Wouldn't be wondering what tomorrow was going to feel like before it even happened." },
    { "type": "narration", "content": "Ethan exhaled." },
    { "type": "narration", "content": "Then typed again." },
    { "type": "internalThought", "character": "Ethan", "content": "Bro… I met someone." },
    { "type": "narration", "content": "He stared at it." },
    { "type": "narration", "content": "This time—" },
    { "type": "narration", "content": "he didn't delete it." },
    { "type": "narration", "content": "His thumb hovered over the screen." },
    { "type": "narration", "content": "Then pressed send." },
    { "type": "message", "sender": "Ethan", "content": "Bro… I met someone." },
    { "type": "narration", "content": "The message disappeared." },
    { "type": "narration", "content": "For a second, nothing happened." },
    { "type": "narration", "content": "Then—" },
    { "type": "narration", "content": "three dots appeared." },
    { "type": "narration", "content": "Ethan leaned forward slightly, watching them like they might disappear if he blinked." },
    { "type": "narration", "content": "He didn't blink." },
    { "type": "narration", "content": "Not yet." }
  ]
}
