{
  "page": 3,
  "chapter": 3,
  "chapterTitle": "Choosing Tomorrow",
  "bookId": "whereWeFirstMet",
  "pov": "Cassandra",
  "blocks": [
    { "type": "narration", "content": "Cassandra had been home for twenty minutes before Lena texted." },
    { "type": "narration", "content": "She was lying on her bed, Harold tucked beside her, the room dim and quiet. She'd taken her medication without thinking—the small act folded so naturally into the end of her days that she barely paused for it anymore. Two pills. A glass of water. A moment where she let the weight of something she usually kept moving to avoid settle briefly, then lifted." },
    { "type": "narration", "content": "She set the glass down." },
    { "type": "narration", "content": "And moved on." },
    { "type": "narration", "content": "Her phone buzzed." },
    { "type": "message", "sender": "Lena", "content": "Okay but CASSANDRA." },
    { "type": "narration", "content": "Cassandra looked at the ceiling." },
    { "type": "message", "sender": "Cassandra", "content": "Good evening to you too." },
    { "type": "message", "sender": "Lena", "content": "Don't good evening me. How was the rest of it." },
    { "type": "message", "sender": "Cassandra", "content": "The rest of what." },
    { "type": "message", "sender": "Lena", "content": "Don't." },
    { "type": "message", "sender": "Lena", "content": "I watched you with him for two hours." },
    { "type": "message", "sender": "Lena", "content": "You smiled at him differently." },
    { "type": "message", "sender": "Cassandra", "content": "I smile at everyone." },
    { "type": "message", "sender": "Lena", "content": "Not like that." },
    { "type": "narration", "content": "Cassandra pressed her lips together." },
    { "type": "narration", "content": "She looked at Harold." },
    { "type": "narration", "content": "Harold looked back with the placid expression of a stuffed bear who had witnessed everything and would say nothing." },
    { "type": "message", "sender": "Cassandra", "content": "He's kind." },
    { "type": "message", "sender": "Lena", "content": "Kind." },
    { "type": "message", "sender": "Lena", "content": "That's the word you're going with." },
    { "type": "message", "sender": "Cassandra", "content": "He's thoughtful. He notices things." },
    { "type": "message", "sender": "Cassandra", "content": "He doesn't talk just to fill space." },
    { "type": "message", "sender": "Lena", "content": "And?" },
    { "type": "narration", "content": "Cassandra stopped typing." },
    { "type": "narration", "content": "Started again." },
    { "type": "message", "sender": "Cassandra", "content": "He makes me feel like the moment is enough." },
    { "type": "narration", "content": "A pause." },
    { "type": "message", "sender": "Lena", "content": "Cass." },
    { "type": "message", "sender": "Cassandra", "content": "I know." },
    { "type": "message", "sender": "Lena", "content": "You know what I'm going to say." },
    { "type": "message", "sender": "Cassandra", "content": "You're going to say be careful." },
    { "type": "message", "sender": "Lena", "content": "I'm going to say be honest." },
    { "type": "message", "sender": "Cassandra", "content": "With him?" },
    { "type": "message", "sender": "Lena", "content": "With yourself. First." },
    { "type": "narration", "content": "Cassandra stared at the screen." },
    { "type": "narration", "content": "Outside, the street had gone quiet. The kind of quiet that arrived after the city stopped pretending and let itself rest." },
    { "type": "narration", "content": "She thought about the thing she hadn't thought about all day." },
    { "type": "narration", "content": "Not because she'd forgotten." },
    { "type": "narration", "content": "But because around Ethan, it had been easier to just be present." },
    { "type": "narration", "content": "That almost scared her more than anything else." },
    { "type": "message", "sender": "Cassandra", "content": "I'm trying." },
    { "type": "message", "sender": "Lena", "content": "I know you are." },
    { "type": "message", "sender": "Lena", "content": "I also know that you light up differently around him." },
    { "type": "message", "sender": "Lena", "content": "And I don't want you to talk yourself out of something good." },
    { "type": "message", "sender": "Cassandra", "content": "What if it gets complicated." },
    { "type": "message", "sender": "Lena", "content": "It already is." },
    { "type": "message", "sender": "Lena", "content": "That's not a reason to stop." },
    { "type": "message", "sender": "Cassandra", "content": "What if I'm not enough time for someone like him." },
    { "type": "narration", "content": "She didn't mean to send it." },
    { "type": "narration", "content": "Or maybe she did." },
    { "type": "narration", "content": "The three dots appeared immediately." },
    { "type": "narration", "content": "Stopped." },
    { "type": "narration", "content": "Then came back." },
    { "type": "message", "sender": "Lena", "content": "You are more than enough." },
    { "type": "message", "sender": "Lena", "content": "And he's lucky if he gets any of your time at all." },
    { "type": "narration", "content": "Cassandra read it twice." },
    { "type": "narration", "content": "Then set the phone face-down on the bed." },
    { "type": "narration", "content": "Her chest was tight." },
    { "type": "narration", "content": "The usual way this time." },
    { "type": "narration", "content": "Just the usual way." }
  ]
}
