{
  "page": 14,
  "chapter": 5,
  "chapterTitle": "Something True",
  "bookId": "whereWeFirstMet",
  "pov": "Cassandra",
  "blocks": [
    { "type": "narration", "content": "She made it home." },
    { "type": "narration", "content": "Her phone lit up as she was taking off her shoes." },
    { "type": "message", "sender": "Lena", "content": "I'm not going to say anything." },
    { "type": "message", "sender": "Cassandra", "content": "Thank you." },
    { "type": "message", "sender": "Lena", "content": "But your hair had paint in it." },
    { "type": "message", "sender": "Cassandra", "content": "I know." },
    { "type": "message", "sender": "Lena", "content": "Like. A lot of paint." },
    { "type": "message", "sender": "Cassandra", "content": "I was aware." },
    { "type": "message", "sender": "Lena", "content": "He has a very good jaw." },
    { "type": "message", "sender": "Cassandra", "content": "Lena." },
    { "type": "message", "sender": "Lena", "content": "I'm just saying. Objectively. As someone who is not saying anything." },
    { "type": "narration", "content": "Cassandra set her phone face-down on the nightstand and lay back on her bed." },
    { "type": "narration", "content": "She looked at her hand, where the blue paint had dried to a faint shadow between her fingers." },
    { "type": "internalThought", "content": "Okay." }
  ]
}
