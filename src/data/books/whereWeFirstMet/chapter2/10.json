{
  "page": 10,
  "chapter": 2,
  "chapterTitle": "The Pull Between Moments",
  "bookId": "whereWeFirstMet",
  "pov": "Cassandra",
  "blocks": [
    { "type": "narration", "content": "Ethan stared at the duck." },
    { "type": "dialogue", "speaker": "Ethan", "content": "That one looks like he has debt." },
    { "type": "narration", "content": "Cassandra burst out laughing." },
    { "type": "narration", "content": "The sound came bright and sudden, spilling into the noise of the arcade until even Ethan looked surprised by it." },
    { "type": "dialogue", "speaker": "Ethan", "content": "What?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "No, you're right." },
    { "type": "narration", "content": "She pointed at the duck." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "That is absolutely a financially burdened duck." },
    { "type": "dialogue", "speaker": "Ethan", "content": "He needs a name." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Obviously." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Walter." },
    { "type": "narration", "content": "Cassandra considered it seriously." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "No." },
    { "type": "dialogue", "speaker": "Ethan", "content": "No?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Walter has structure. This duck is one bad decision away from tax fraud." },
    { "type": "narration", "content": "Ethan looked back at the duck." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Gerald?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Gerald owes someone money." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Perfect." },
    { "type": "narration", "content": "Cassandra nodded." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Gerald it is." },
    { "type": "narration", "content": "Ethan smiled, and the expression did something to his whole face." },
    { "type": "narration", "content": "Softened it." },
    { "type": "narration", "content": "Opened it." },
    { "type": "narration", "content": "Cassandra looked away first." },
    { "type": "narration", "content": "Not because she wanted to." },
    { "type": "narration", "content": "Because she did not." },
    { "type": "narration", "content": "That was worse." },
    { "type": "narration", "content": "She fed a token into the machine." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Ladies first?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Winners first." },
    { "type": "dialogue", "speaker": "Ethan", "content": "You haven't won yet." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I live prophetically." },
    { "type": "narration", "content": "Cassandra guided the claw with exaggerated seriousness. Ethan stood beside her, trying not to seem invested and failing completely." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Left." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I know." },
    { "type": "dialogue", "speaker": "Ethan", "content": "A little more." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I know." },
    { "type": "dialogue", "speaker": "Ethan", "content": "You're too far." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Do you want to drive?" },
    { "type": "dialogue", "speaker": "Ethan", "content": "No." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Then suffer quietly." },
    { "type": "narration", "content": "She pressed the button." },
    { "type": "narration", "content": "The claw dropped." },
    { "type": "narration", "content": "Closed." },
    { "type": "narration", "content": "Caught Gerald by the bow tie." },
    { "type": "narration", "content": "Lifted." },
    { "type": "narration", "content": "For one glorious second, hope existed." },
    { "type": "narration", "content": "Then Gerald fell." },
    { "type": "narration", "content": "Cassandra gasped like betrayal had a body." },
    { "type": "narration", "content": "Ethan laughed so hard he had to look away." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "That was not funny." },
    { "type": "dialogue", "speaker": "Ethan", "content": "It was a little funny." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Gerald trusted us." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Gerald has made questionable choices." },
    { "type": "narration", "content": "She looked at him." },
    { "type": "narration", "content": "Then laughed too." },
    { "type": "narration", "content": "For a while, that was all it was." },
    { "type": "narration", "content": "Tokens." },
    { "type": "narration", "content": "Failed attempts." },
    { "type": "narration", "content": "Ridiculous names." },
    { "type": "narration", "content": "A turtle called Professor Beans." },
    { "type": "narration", "content": "A fox named Marigold because Cassandra insisted she had \"main character sorrow.\"" },
    { "type": "narration", "content": "A blue bear Ethan quietly named Harold, which Cassandra tried to reject until he defended Harold's gentle dignity with surprising passion." },
    { "type": "narration", "content": "And slowly, without either of them saying it, the space between them changed." },
    { "type": "narration", "content": "Not dramatically." },
    { "type": "narration", "content": "Not suddenly." },
    { "type": "narration", "content": "Just enough." },
    { "type": "narration", "content": "Like a chair pulled closer." },
    { "type": "narration", "content": "Like a page turning." }
  ]
}
