{
  "page": 3,
  "chapter": 2,
  "chapterTitle": "The Pull Between Moments",
  "bookId": "whereWeFirstMet",
  "pov": "Cassandra",
  "blocks": [
    { "type": "narration", "content": "Her phone buzzed on the nightstand." },
    { "type": "message", "sender": "Maya", "recipient": "Cassandra", "content": "Morning. Don't forget." },
    { "type": "narration", "content": "Cassandra stared at the message." },
    { "type": "narration", "content": "No good morning." },
    { "type": "narration", "content": "No heart emoji." },
    { "type": "narration", "content": "Just don't forget." },
    { "type": "narration", "content": "Maya had the emotional subtlety of a locked medicine cabinet." },
    { "type": "narration", "content": "Cassandra typed back:" },
    { "type": "message", "sender": "Cassandra", "recipient": "Maya", "content": "Good morning to you too, radiant flower of tenderness." },
    { "type": "narration", "content": "The reply came almost immediately." },
    { "type": "message", "sender": "Maya", "recipient": "Cassandra", "content": "Cassandra." },
    { "type": "narration", "content": "Cassandra grinned." },
    { "type": "message", "sender": "Cassandra", "recipient": "Maya", "content": "Fine. I won't forget." },
    { "type": "narration", "content": "Three dots appeared." },
    { "type": "narration", "content": "Disappeared." },
    { "type": "narration", "content": "Appeared again." },
    { "type": "narration", "content": "Then:" },
    { "type": "message", "sender": "Maya", "recipient": "Cassandra", "content": "Please." },
    { "type": "narration", "content": "That one word softened everything." },
    { "type": "narration", "content": "Cassandra's thumb hovered over the screen." },
    { "type": "narration", "content": "Her smile dimmed, not gone, just lowered like a lamp turned down for night." },
    { "type": "message", "sender": "Cassandra", "recipient": "Maya", "content": "I promise." },
    { "type": "narration", "content": "She set the phone aside and looked toward the small bottle on her nightstand." },
    { "type": "narration", "content": "For a moment, she did nothing." },
    { "type": "narration", "content": "Then she took what she needed, swallowed, and stood before the room could turn serious around her." },
    { "type": "narration", "content": "Serious rooms were dangerous." },
    { "type": "narration", "content": "They made people think." },
    { "type": "narration", "content": "Cassandra preferred movement." },
    { "type": "narration", "content": "She crossed to her closet and pulled out a yellow sweater, then changed her mind and grabbed the soft green jacket from yesterday instead." },
    { "type": "narration", "content": "She held it in front of herself." },
    { "type": "narration", "content": "There was nothing special about it." },
    { "type": "narration", "content": "Just fabric. Sleeves. A zipper that stuck if she pulled too quickly." },
    { "type": "narration", "content": "Still, her fingers lingered on the collar." },
    { "type": "narration", "content": "The park came back to her in pieces." },
    { "type": "narration", "content": "The stone archway." },
    { "type": "narration", "content": "The weak fountain." },
    { "type": "narration", "content": "The easel." },
    { "type": "narration", "content": "Ethan looking like he had been caught committing a crime when all he had done was paint." },
    { "type": "narration", "content": "She smiled before she could stop herself." },
    { "type": "narration", "content": "Then she caught her own reflection in the closet mirror." },
    { "type": "narration", "content": "Red hair slightly tangled. Eyes a little tired. Green jacket in hand." },
    { "type": "narration", "content": "A girl smiling at a memory she had no business keeping." },
    { "type": "internalThought", "character": "Cassandra", "content": "Careful," },
    { "type": "narration", "content": "she thought." },
    { "type": "narration", "content": "The word arrived softly, but it had teeth." },
    { "type": "narration", "content": "Cassandra lifted her chin." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Nope. Not doing that today." },
    { "type": "narration", "content": "She put on the jacket." }
  ]
}
