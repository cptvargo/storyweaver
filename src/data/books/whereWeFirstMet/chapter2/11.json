{
  "page": 11,
  "chapter": 2,
  "chapterTitle": "The Pull Between Moments",
  "bookId": "whereWeFirstMet",
  "pov": "Ethan",
  "blocks": [
    { "type": "narration", "content": "Ethan won Harold on the fifth try." },
    { "type": "narration", "content": "It was not graceful." },
    { "type": "narration", "content": "The claw caught the blue bear by one ear, dragged him across the pile upside down, dropped him, picked him up again in what Ethan could only describe as an emotionally complicated rescue operation, then finally released him into the prize slot with an aggressive plastic thud." },
    { "type": "narration", "content": "Cassandra cheered like he had returned from battle." },
    { "type": "dialogue", "speaker": "Ethan", "content": "I told you he had dignity." },
    { "type": "narration", "content": "Ethan said, lifting the bear." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "He was carried by one ear." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Dignity under pressure." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Very different thing." },
    { "type": "narration", "content": "Ethan held the bear out to her." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "What are you doing?" },
    { "type": "dialogue", "speaker": "Ethan", "content": "Giving you Harold." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "You won him." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Barely." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "That still counts." },
    { "type": "dialogue", "speaker": "Ethan", "content": "He has main character sorrow." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "That was Marigold." },
    { "type": "dialogue", "speaker": "Ethan", "content": "I think Harold has quiet supporting character sorrow." },
    { "type": "narration", "content": "Cassandra stared at him for a second." },
    { "type": "narration", "content": "Then took the bear carefully, like he had given her something far more fragile than cheap fabric and stuffing." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Thank you." },
    { "type": "narration", "content": "Softly." },
    { "type": "narration", "content": "Too softly for the arcade." },
    { "type": "narration", "content": "Ethan looked down, suddenly very interested in the prize slot." },
    { "type": "dialogue", "speaker": "Ethan", "content": "You're welcome." },
    { "type": "narration", "content": "Cassandra tucked Harold under one arm." },
    { "type": "narration", "content": "Then she turned back to the machine with new determination." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I'm getting Gerald." },
    { "type": "dialogue", "speaker": "Ethan", "content": "You don't have to." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I absolutely have to." },
    { "type": "narration", "content": "Gerald took three more attempts and one mild accusation of mechanical corruption." },
    { "type": "narration", "content": "When Cassandra finally won him, the yellow duck dropped into the slot like justice had been restored." },
    { "type": "narration", "content": "She held him up triumphantly." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Gerald has been freed from the burden of capitalism." },
    { "type": "dialogue", "speaker": "Ethan", "content": "That's a lot for a duck." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "He's resilient." },
    { "type": "narration", "content": "Then Cassandra held Gerald out to him." },
    { "type": "narration", "content": "Ethan looked at the duck." },
    { "type": "narration", "content": "Then at her." },
    { "type": "dialogue", "speaker": "Ethan", "content": "No." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Yes." },
    { "type": "dialogue", "speaker": "Ethan", "content": "You won him." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "And you gave me Harold." },
    { "type": "dialogue", "speaker": "Ethan", "content": "That was different." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "How?" },
    { "type": "dialogue", "speaker": "Ethan", "content": "I don't know yet." },
    { "type": "narration", "content": "She stepped closer and pushed Gerald gently into his hands." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Then figure it out later." },
    { "type": "narration", "content": "Ethan took him." },
    { "type": "narration", "content": "Gerald's bow tie was crooked." },
    { "type": "narration", "content": "His stitching looked questionable." },
    { "type": "narration", "content": "His face carried the permanent expression of someone who had seen too much for a toy produced in bulk." },
    { "type": "narration", "content": "Ethan loved him immediately." },
    { "type": "narration", "content": "Which was unfortunate." },
    { "type": "narration", "content": "Cassandra smiled like she knew." },
    { "type": "narration", "content": "Then, just as quickly, her smile flickered." },
    { "type": "narration", "content": "Her hand moved to the side of the claw machine, fingers curling against the metal edge." },
    { "type": "narration", "content": "Ethan noticed before he meant to." },
    { "type": "narration", "content": "The color had not left her face exactly." },
    { "type": "narration", "content": "But something had shifted." },
    { "type": "narration", "content": "A pause beneath the brightness." },
    { "type": "narration", "content": "A small absence." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Cassandra?" },
    { "type": "narration", "content": "She blinked and looked at him." },
    { "type": "narration", "content": "For a second, her eyes seemed far away." },
    { "type": "narration", "content": "Then she was back." },
    { "type": "narration", "content": "Completely back." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "What?" },
    { "type": "dialogue", "speaker": "Ethan", "content": "Are you okay?" },
    { "type": "narration", "content": "She looked down at her hand, still gripping the machine, and released it." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Yeah." },
    { "type": "narration", "content": "Too fast." },
    { "type": "narration", "content": "Again." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I think Gerald's freedom overwhelmed me." },
    { "type": "narration", "content": "Ethan did not laugh right away." },
    { "type": "narration", "content": "He wanted to." },
    { "type": "narration", "content": "The joke was easy." },
    { "type": "narration", "content": "She was asking him to take the easy door." },
    { "type": "narration", "content": "But something in him hesitated." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Are you sure?" },
    { "type": "narration", "content": "Cassandra's expression softened." },
    { "type": "narration", "content": "Not annoyed." },
    { "type": "narration", "content": "Not defensive." },
    { "type": "narration", "content": "Just aware." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I'm sure." },
    { "type": "narration", "content": "Then she lifted Harold slightly." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Besides, I have emotional support now." },
    { "type": "narration", "content": "Ethan looked at the blue bear tucked under her arm." },
    { "type": "dialogue", "speaker": "Ethan", "content": "He's very qualified." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Clearly." },
    { "type": "narration", "content": "The moment passed." },
    { "type": "narration", "content": "Or seemed to." },
    { "type": "narration", "content": "Lena watched from behind the counter." },
    { "type": "narration", "content": "Ethan noticed that too." },
    { "type": "narration", "content": "Her expression was not playful anymore." },
    { "type": "narration", "content": "It was careful." },
    { "type": "narration", "content": "Protective." },
    { "type": "narration", "content": "Like Maya's texts." },
    { "type": "narration", "content": "Like Cassandra's too-fast answers." },
    { "type": "narration", "content": "Like something existed just outside the edge of the picture." },
    { "type": "narration", "content": "Something Ethan could not see yet." },
    { "type": "narration", "content": "He looked at Cassandra again." },
    { "type": "narration", "content": "She was smiling now, teasing Gerald's crooked bow tie with one finger." },
    { "type": "narration", "content": "Maybe he was imagining things." },
    { "type": "narration", "content": "He was good at that." },
    { "type": "narration", "content": "Still, when Cassandra said, \"Come on, technically Ethan, there's one more machine you need to lose at,\" he followed." },
    { "type": "narration", "content": "But a small part of him stayed back with that pause." }
  ]
}
