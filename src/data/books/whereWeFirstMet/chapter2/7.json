{
  "page": 7,
  "chapter": 2,
  "chapterTitle": "The Pull Between Moments",
  "bookId": "whereWeFirstMet",
  "blocks": [
    { "type": "narration", "content": "They talked about coffee first." },
    { "type": "narration", "content": "That was safe." },
    { "type": "narration", "content": "Coffee had structure. Preferences. Logic." },
    { "type": "narration", "content": "Cassandra ordered iced coffee even though it was barely warm outside, because apparently temperature was a suggestion and not a rule." },
    { "type": "narration", "content": "Ethan kept his usual black coffee with two sugars." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Two sugars?" },
    { "type": "dialogue", "speaker": "Ethan", "content": "Yes." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "That feels like a compromise." },
    { "type": "dialogue", "speaker": "Ethan", "content": "With what?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Your personality." },
    { "type": "dialogue", "speaker": "Ethan", "content": "My personality needs sugar?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I'm saying you seem like someone who wants to drink black coffee but secretly believes life should be kinder." },
    { "type": "narration", "content": "He stared at her for a second." },
    { "type": "narration", "content": "Then looked down at his cup." },
    { "type": "dialogue", "speaker": "Ethan", "content": "That is… alarmingly specific." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I'm very gifted." },
    { "type": "dialogue", "speaker": "Ethan", "content": "At reading coffee orders?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "At noticing contradictions." },
    { "type": "narration", "content": "Ethan smiled faintly." },
    { "type": "narration", "content": "He should have felt exposed." },
    { "type": "narration", "content": "Maybe he did." },
    { "type": "narration", "content": "But it was not unpleasant." },
    { "type": "narration", "content": "It felt more like someone opening a window in a room he had forgotten was stuffy." },
    { "type": "narration", "content": "Cassandra stirred her iced coffee with a straw, the ice clicking softly against the glass." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "What do you usually paint?" },
    { "type": "dialogue", "speaker": "Ethan", "content": "Whatever people ask me to." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "That sounds depressing." },
    { "type": "dialogue", "speaker": "Ethan", "content": "It pays occasionally." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Occasionally also sounds depressing." },
    { "type": "dialogue", "speaker": "Ethan", "content": "It is a very emotionally complex career path." },
    { "type": "narration", "content": "She rested her chin on one hand." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "What would you paint if nobody asked?" },
    { "type": "narration", "content": "The question slowed him." },
    { "type": "narration", "content": "Most people asked what he did." },
    { "type": "narration", "content": "They did not ask what he wanted." },
    { "type": "narration", "content": "Ethan looked toward the window." },
    { "type": "narration", "content": "Outside, a delivery truck rolled past, blocking the view for a few seconds before the street returned." },
    { "type": "dialogue", "speaker": "Ethan", "content": "I don't know," },
    { "type": "narration", "content": "he said." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "You don't know, or you don't say it out loud?" },
    { "type": "narration", "content": "He looked back at her." },
    { "type": "narration", "content": "She was not teasing now." },
    { "type": "narration", "content": "Not exactly." },
    { "type": "dialogue", "speaker": "Ethan", "content": "I think," },
    { "type": "narration", "content": "he said carefully," },
    { "type": "dialogue", "speaker": "Ethan", "content": "I'd paint things people usually miss." },
    { "type": "narration", "content": "Cassandra's expression softened." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "The small stuff?" },
    { "type": "dialogue", "speaker": "Ethan", "content": "Maybe." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Like what?" },
    { "type": "narration", "content": "Ethan glanced down at his sketchbook." },
    { "type": "dialogue", "speaker": "Ethan", "content": "The way light hits old brick. Or how people stand when they're waiting for something. Or places that look ordinary until something happens there." },
    { "type": "narration", "content": "Cassandra was quiet." },
    { "type": "narration", "content": "For once, she did not jump in with a joke." },
    { "type": "narration", "content": "That made him nervous." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Sorry. That sounded—" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Beautiful," },
    { "type": "narration", "content": "she said." },
    { "type": "narration", "content": "The word stopped him." },
    { "type": "narration", "content": "She said it simply." },
    { "type": "narration", "content": "No performance." },
    { "type": "narration", "content": "No exaggeration." },
    { "type": "narration", "content": "Just beautiful." }
  ]
}
