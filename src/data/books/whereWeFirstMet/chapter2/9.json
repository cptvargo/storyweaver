{
  "page": 9,
  "chapter": 2,
  "chapterTitle": "The Pull Between Moments",
  "bookId": "whereWeFirstMet",
  "pov": "Cassandra",
  "blocks": [
    { "type": "narration", "content": "The arcade looked different with Ethan inside it." },
    { "type": "narration", "content": "Cassandra noticed that immediately." },
    { "type": "narration", "content": "Not because the arcade changed." },
    { "type": "narration", "content": "It was still loud, bright, slightly sticky, and full of machines that made victory sound possible even when it statistically was not." },
    { "type": "narration", "content": "But Ethan entered like a person stepping into someone else's dream." },
    { "type": "narration", "content": "Carefully." },
    { "type": "narration", "content": "Almost apologetically." },
    { "type": "narration", "content": "His eyes moved everywhere." },
    { "type": "narration", "content": "The racing game." },
    { "type": "narration", "content": "The prize counter." },
    { "type": "narration", "content": "The cracked basketball machine." },
    { "type": "narration", "content": "The claw machines glowing in the back like tiny glass kingdoms full of impossible rescues." },
    { "type": "narration", "content": "Cassandra watched him watching." },
    { "type": "narration", "content": "That was becoming dangerous." },
    { "type": "narration", "content": "Because Ethan did not look at things casually." },
    { "type": "narration", "content": "He received them." },
    { "type": "narration", "content": "Like details mattered." },
    { "type": "narration", "content": "Like the world was constantly offering him pieces of itself and he felt responsible for not dropping them." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "You okay?" },
    { "type": "dialogue", "speaker": "Ethan", "content": "This place is… a lot." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "That's its best quality." },
    { "type": "dialogue", "speaker": "Ethan", "content": "It feels like every machine is yelling at me in a different language." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Exactly. Multicultural." },
    { "type": "narration", "content": "He laughed, and Cassandra felt the sound settle somewhere warm." },
    { "type": "narration", "content": "Lena looked up from behind the prize counter and froze." },
    { "type": "narration", "content": "Cassandra lifted one hand." },
    { "type": "narration", "content": "Lena's eyes moved from Cassandra to Ethan and back again." },
    { "type": "narration", "content": "Then her face slowly became the face of someone learning information they planned to use irresponsibly." },
    { "type": "narration", "content": "Cassandra narrowed her eyes." },
    { "type": "narration", "content": "Don't." },
    { "type": "narration", "content": "Lena smiled." },
    { "type": "narration", "content": "Absolutely." },
    { "type": "dialogue", "speaker": "Lena", "content": "Hi," },
    { "type": "narration", "content": "Lena called." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Hi." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "This is Ethan," },
    { "type": "narration", "content": "Cassandra said quickly." },
    { "type": "dialogue", "speaker": "Lena", "content": "The painter." },
    { "type": "narration", "content": "Ethan looked at Cassandra." },
    { "type": "narration", "content": "Cassandra looked at the ceiling." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "I may have mentioned you." },
    { "type": "dialogue", "speaker": "Ethan", "content": "To what extent?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "A normal extent." },
    { "type": "narration", "content": "Lena made a sound that suggested the truth was very tired." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "We're playing." },
    { "type": "dialogue", "speaker": "Lena", "content": "Are you warning me or inviting me?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Neither. I'm establishing dominance." },
    { "type": "dialogue", "speaker": "Lena", "content": "Against the machine?" },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Against fate." },
    { "type": "narration", "content": "Ethan leaned closer to Cassandra." },
    { "type": "dialogue", "speaker": "Ethan", "content": "Does she always talk like this?" },
    { "type": "narration", "content": "Lena answered before Cassandra could." },
    { "type": "dialogue", "speaker": "Lena", "content": "Yes." },
    { "type": "dialogue", "speaker": "Cassandra", "content": "Only when I'm right." },
    { "type": "narration", "content": "They reached the claw machine near the back—the same one Winston had been liberated from. Today, the machine was stocked with a new batch of animals: a crooked fox, a sleepy blue bear, a turtle with one suspiciously dramatic eyebrow, and a tiny yellow duck wearing what appeared to be a bow tie." }
  ]
}
