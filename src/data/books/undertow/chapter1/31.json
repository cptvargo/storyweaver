    { "type": "dialogue", "speaker": "Dean Ashby", "content": "He's not breathing." },
    { "type": "dialogue", "speaker": "Sophie Laurent", "content": "No. No no no —" },
    { "type": "dialogue", "speaker": "Dean Ashby", "content": "Sophie, get back." },
