    { "type": "dialogue", "speaker": "Sophie Laurent", "content": "He was fine. He was at dinner, he was fine —" },
    { "type": "dialogue", "speaker": "Dean Ashby", "content": "Sophie. Outside. Now." },
    { "type": "dialogue", "speaker": "Cade Mercer", "content": "Marcus." },
    { "type": "dialogue", "speaker": "Dean Ashby", "content": "Don't touch anything. Don't touch anything in here." },
    { "type": "internalThought", "content": "The window was open. The room was forty-seven degrees. The water glass on the nightstand was half empty. He looked like he had simply stopped." },
    { "type": "dialogue", "speaker": "Nadia Reyes", "content": "Is he —" },
    { "type": "dialogue", "speaker": "Dean Ashby", "content": "Yes." },
    { "type": "dialogue", "speaker": "Nadia Reyes", "content": "Dean." },
    { "type": "dialogue", "speaker": "Dean Ashby", "content": "Get everyone downstairs. Please." },
