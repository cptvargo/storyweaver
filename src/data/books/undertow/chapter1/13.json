  "chapterTitle": "The Weekend",
  "bookId": "undertow",
  "blocks": [
    { "type": "dialogue", "speaker": "Mara Voss", "content": "Good night, everyone." },
    { "type": "dialogue", "speaker": "Marcus Calloway", "content": "Come back tomorrow. We'll be on the beach most of the day." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "We might take you up on that." },
    { "type": "dialogue", "speaker": "Marcus Calloway", "content": "No might about it. The water's perfect in the morning." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "Good night." },
    { "type": "dialogue", "speaker": "Dean Ashby", "content": "Night." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "That was actually really nice." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "Yes." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "You enjoyed yourself." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "Parts of it." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "The parts where you weren't running behavioral profiles." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "Those parts too." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "The Appalachian Trail story was funny." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "It was." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "You laughed." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "I did." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "See." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "See what?" },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "Nothing. Good night, Julian." },
    { "type": "internalThought", "content": "She said it differently than she usually did. I didn't say anything about it." },
    { "type": "choice", "prompt": "What does Julian do?", "options": [
      { "id": "ep1_goodnight_nothing", "label": "\"Good night.\" He goes inside." },
      { "id": "ep1_goodnight_pause", "label": "He pauses at the door. One beat. Then goes inside." }
    ]}
  ]
