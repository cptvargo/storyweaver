    { "type": "consequence", "character": "Julian", "text": "noted it. Every answer Nadia gave was exactly right. Not a word more than needed.", "condition": "ep1_marcus_nadia_deflect" },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "You're doing it." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "I'm sitting here." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "You're sitting here and watching that woman like she's a case file." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "I'm not." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "Julian." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "She deflected six questions in four minutes." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "She's tired from the drive." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "That's what she said." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "Because it's true." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "People who are tired from a drive say less. They don't answer questions with exactly the right amount of words every single time." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "Some people are just private." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "Yes." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "We're on vacation." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "I know." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "And she hasn't done anything." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "No." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "Then stop." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "I'm stopped." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "Your version of stopped and my version of stopped are very different things." },
    { "type": "choice", "prompt": "Does Julian stop?", "options": [
      { "id": "ep1_julian_stops", "label": "He tries. He looks at the fire instead." },
      { "id": "ep1_julian_keeps_watching", "label": "Not completely. He just gets quieter about it." }
