      "condition": "ep1_tabled_it"
    },
    {
      "type": "consequence",
      "character": "Julian",
      "text": "sat down and said nothing about any of it.",
      "condition": "ep1_p16_silent"
    },
    {
      "type": "dialogue",
      "speaker": "Marcus Calloway",
      "content": "You made it out."
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "Told you we might."
    },
    {
      "type": "dialogue",
      "speaker": "Marcus Calloway",
      "content": "No might about it. The coast decided."
    },
    {
      "type": "dialogue",
      "speaker": "Sophie Laurent",
      "content": "The water is so cold though. Dean went in."
    },
    {
      "type": "dialogue",
      "speaker": "Dean Ashby",
      "content": "It's not that cold."
    },
    {
      "type": "dialogue",
      "speaker": "Sophie Laurent",
      "content": "He turned blue."
    },
    {
      "type": "dialogue",
      "speaker": "Dean Ashby",
      "content": "I did not turn blue."
    },
    {
      "type": "dialogue",
      "speaker": "Nadia Reyes",
      "content": "A very healthy shade of blue."
    },
    {
      "type": "dialogue",
      "speaker": "Dean Ashby",
      "content": "You all are against me."
    },
    {
      "type": "dialogue",
      "speaker": "Marcus Calloway",
      "content": "The ocean is against you."
    },
    {
      "type": "dialogue",
      "speaker": "Cade Mercer",
      "content": "The thermometer is against you."
    },
    {
      "type": "dialogue",
      "speaker": "Wren Cole",
      "content": "Science is against you."
    },
    {
      "type": "dialogue",
      "speaker": "Dean Ashby",
      "content": "Thank you, Wren."
    },
    {
      "type": "dialogue",
      "speaker": "Wren Cole",
      "content": "Anytime."
    },
    {
      "type": "internalThought",
      "content": "Nadia was the most visibly present she had been all weekend. Laughing first. Moving between conversations. She had positioned herself where everyone could see her.",
      "mindOf": "Julian"
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "Do you want to go in?"
    },
    {
