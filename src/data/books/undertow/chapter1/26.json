    {
      "type": "consequence",
      "character": "Julian",
      "text": "had said nothing. He carried it out of the house without a name on it.",
      "condition": "ep1_p25_silent"
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "Talk to me."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "About what?"
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "About whatever is happening in your head right now."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "Nothing is happening."
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "You've gone quiet. Your specific kind of quiet."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "There are different kinds?"
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "You have at least four. This is the one where you're building something."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "I'm not building anything."
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "Two voices. One argument. Nobody went up to check. They all looked away."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "People argue."
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "Julian."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "Mara."
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "We don't know anything."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "We know someone didn't come back downstairs."
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "Because they went to bed."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "Possibly."
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "Probably."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "Yes."
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "Get some sleep. It was a long day."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "I'll be in soon."
    },
    {
      "type": "dialogue",
      "speaker": "Mara Voss",
      "content": "Don't stay on that porch all night."
    },
    {
      "type": "dialogue",
      "speaker": "Julian Crane",
      "content": "I won't."
    },
