{
  "page": 2,
  "chapter": 1,
  "chapterTitle": "The Weekend",
  "bookId": "undertow",
  "blocks": [
    { "type": "dialogue", "speaker": "Mara Voss", "content": "No cases." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "I'm aware." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "I'm saying it out loud because awareness hasn't historically been enough." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "I know how to take a vacation." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "Name one." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "This will be the first." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "That's what I thought." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "No behavioral analysis. No reading people. No going completely still when someone says something and you're already three layers deep into what it means." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "I don't go still." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "You went still just now." },
    { "type": "dialogue", "speaker": "Julian Crane", "content": "I was thinking." },
    { "type": "dialogue", "speaker": "Mara Voss", "content": "That's the same thing." },
    {
      "type": "choice",
      "prompt": "What does Julian say?",
      "options": [
        { "id": "ep1_julian_agree", "label": "\"Fine. No work. I'll be present.\"" },
        { "id": "ep1_julian_honest", "label": "\"I don't know how to turn it off.\"" },
        { "id": "ep1_julian_deflect", "label": "\"How much further?\"" }
      ]
    }
  ]
}
