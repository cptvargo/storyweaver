      "pov": "Larry",
      "condition": "asked_number_ep2"
    },
    {
      "type": "dialogue",
      "speaker": "Crystal",
      "content": "I know I don't have to. I'm saying it because it's true.",
      "platform": "SMS",
      "pov": "Larry",
      "condition": "asked_number_ep2"
    },
    {
      "type": "internalThought",
      "content": "I held the phone for a moment longer than I needed to.",
