    { "type": "dialogue", "speaker": "Ms. Barrett", "content": "Good. Next.", "condition": "intro_math" },
    { "type": "dialogue", "speaker": "Ms. Barrett", "content": "We already have one. One thing, please.", "condition": "intro_lied" },
    { "type": "dialogue", "speaker": "Ms. Barrett", "content": "One thing. Anything at all.", "condition": "intro_name_only" },
    { "type": "dialogue", "speaker": "Ms. Barrett", "content": "That's okay. We'll come back to you.", "condition": "intro_froze" },
    { "type": "internalThought", "content": "She turned around. Not to laugh. Just to look at me — like she was deciding something." },
    { "type": "dialogue", "speaker": "Maya", "content": "I'm good at math too. Maya Reeves.", "condition": "intro_math" },
    { "type": "dialogue", "speaker": "Maya", "content": "Wide receiver. Really.", "condition": "intro_lied" },
    { "type": "dialogue", "speaker": "Maya", "content": "Okay. Maya Reeves. That's more than you gave us.", "condition": "intro_name_only" },
    { "type": "dialogue", "speaker": "Maya", "content": "Hey. It happens. Maya Reeves.", "condition": "intro_froze" },
    { "type": "dialogue", "speaker": "Larry", "content": "Does Ms. Barrett know you just turned around?", "condition": "intro_math" },
    { "type": "dialogue", "speaker": "Larry", "content": "It's — look, it's complicated.", "condition": "intro_lied" },
    { "type": "dialogue", "speaker": "Larry", "content": "You still gave more than I did.", "condition": "intro_name_only" },
    { "type": "dialogue", "speaker": "Larry", "content": "I'm not usually like that.", "condition": "intro_froze" },
    { "type": "dialogue", "speaker": "Maya", "content": "She does. I don't care.", "condition": "intro_math" },
    { "type": "dialogue", "speaker": "Maya", "content": "Sure it is.", "condition": "intro_lied" },
    { "type": "dialogue", "speaker": "Maya", "content": "I know.", "condition": "intro_name_only" },
    { "type": "dialogue", "speaker": "Maya", "content": "I don't know you well enough to say that yet.", "condition": "intro_froze" },
    { "type": "dialogue", "speaker": "Larry", "content": "You always introduce yourself to people who embarrass themselves?", "condition": "intro_math" },
    { "type": "dialogue", "speaker": "Larry", "content": "You don't believe me.", "condition": "intro_lied" },
    { "type": "dialogue", "speaker": "Larry", "content": "Fair.", "condition": "intro_name_only" },
    { "type": "dialogue", "speaker": "Maya", "content": "Only the ones who say it like it's a bad thing.", "condition": "intro_math" },
    { "type": "dialogue", "speaker": "Maya", "content": "Not yet.", "condition": "intro_lied" },
    {
      "type": "choice",
      "prompt": "Ms. Barrett is still going. Maya is still looking at you.",
      "options": [
        { "id": "introduced_proper", "label": "\"Larry. Nice to meet you.\"", "goto": 5 },
        { "id": "asked_maya", "label": "\"What kind of math?\"", "goto": 5 },
        { "id": "nodded_maya", "label": "Just nod. Play it cool.", "goto": 5 },
        { "id": "blanked_maya", "label": "...", "goto": 5 }
      ]
    }
  ]
