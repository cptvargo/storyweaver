    { "type": "dialogue", "speaker": "Larry", "content": "You don't even start school for two more weeks." },
    { "type": "dialogue", "speaker": "Larry Jr.", "content": "I know. But you do." },
    { "type": "dialogue", "speaker": "Larry Jr.", "content": "Is it a big school?" },
    { "type": "dialogue", "speaker": "Larry", "content": "Yeah." },
    { "type": "dialogue", "speaker": "Larry Jr.", "content": "Bigger than Jefferson?" },
    { "type": "dialogue", "speaker": "Larry", "content": "A lot bigger." },
    { "type": "dialogue", "speaker": "Larry Jr.", "content": "Are you nervous?" },
    { "type": "internalThought", "content": "I looked at him. He wasn't asking to be funny. He was just asking." },
