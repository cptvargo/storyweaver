    { "type": "dialogue", "speaker": "Larry", "content": "I didn't say anything." },
    { "type": "dialogue", "speaker": "Daniel", "content": "Yeah. That's the point." },
    { "type": "internalThought", "content": "He walked off. Not in a hurry. Like he'd finished something." },
    { "type": "internalThought", "content": "I stood there for a second longer than I should have. The two girls near the fountain weren't looking. But they'd heard." },
    { "type": "internalThought", "content": "Jonathan found me two minutes later. He'd been at his locker. He knew from my face before I said a word." },
    { "type": "dialogue", "speaker": "Jonathan", "content": "Aye — that was Daniel Snyder." },
    { "type": "dialogue", "speaker": "Larry", "content": "I know." },
    { "type": "dialogue", "speaker": "Jonathan", "content": "He step to you?" },
    { "type": "dialogue", "speaker": "Larry", "content": "Just questions." },
    { "type": "dialogue", "speaker": "Jonathan", "content": "And what you say back?" },
    { "type": "dialogue", "speaker": "Larry", "content": "Nothing." },
    { "type": "dialogue", "speaker": "Jonathan", "content": "Bruh." },
    { "type": "dialogue", "speaker": "Larry", "content": "I handled it." },
    { "type": "dialogue", "speaker": "Jonathan", "content": "Nah. You didn't handle it. Now he thinks he can run up on you whenever. You just handed him that fr." },
    { "type": "consequence", "id": "jonathan_clocked_it", "character": "Jonathan", "text": "saw what happened with Daniel." },
