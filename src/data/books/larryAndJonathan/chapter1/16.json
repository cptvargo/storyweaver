    { "type": "dialogue", "speaker": "Larry", "content": "Ha. Honest answer? Same." },
    { "type": "internalThought", "content": "He blinked. Then — slow, like he was deciding whether to let it through — he laughed. Short. Real." },
    { "type": "dialogue", "speaker": "Daniel", "content": "Aight. That's actually funny." },
    { "type": "dialogue", "speaker": "Larry", "content": "I wasn't trying to be." },
    { "type": "dialogue", "speaker": "Daniel", "content": "That's what made it funny." },
    { "type": "internalThought", "content": "He didn't move out of the way so much as just stop being a wall." },
    { "type": "dialogue", "speaker": "Imani", "content": "How'd you do that?" },
    { "type": "dialogue", "speaker": "Larry", "content": "Do what?" },
    { "type": "dialogue", "speaker": "Imani", "content": "Nobody makes Daniel laugh. Like — ever. Especially not on the first day." },
    { "type": "dialogue", "speaker": "Larry", "content": "I just told the truth." },
    { "type": "dialogue", "speaker": "Imani", "content": "Yeah. That's exactly why." },
    { "type": "consequence", "id": "made_daniel_laugh", "character": "Daniel Snyder", "text": "will remember that." },
    {
      "type": "choice",
      "prompt": "She's still looking at you.",
