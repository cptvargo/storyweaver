    { "type": "narration", "content": "9:47 PM." },
    { "type": "narration", "content": "Larry was at his desk. The house was quiet in the way it was always quiet — his father was in Dallas or Denver or somewhere with a conference room and a flight back on Thursday, and the silence had a specific texture to it that Larry had stopped noticing years ago. Almost." },
    { "type": "narration", "content": "The AIM notification sound." },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "first day tho" },
    { "type": "message", "platform": "AIM", "sender": "LJ_Jenkins05", "recipient": "JMoss_WR1", "content": "yeah" },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "watchu think" },
    { "type": "message", "platform": "AIM", "sender": "LJ_Jenkins05", "recipient": "JMoss_WR1", "content": "its school" },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "lmaoo" },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "aye you shouldve pulled up to the table earlier bro. marcus was asking bout you after" },
    { "type": "message", "platform": "AIM", "sender": "LJ_Jenkins05", "recipient": "JMoss_WR1", "content": "..." },
    { "type": "message", "platform": "AIM", "sender": "LJ_Jenkins05", "recipient": "JMoss_WR1", "content": "what about the daniel snyder thing" },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "what about it" },
    { "type": "message", "platform": "AIM", "sender": "LJ_Jenkins05", "recipient": "JMoss_WR1", "content": "you were right there" },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "i saw" },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "aye just don't be out here making enemies on day one lar. that ain't worth it" },
    { "type": "message", "platform": "AIM", "sender": "LJ_Jenkins05", "recipient": "JMoss_WR1", "content": "i wasnt the one who started it" },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "i know" },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "just saying" },
    { "type": "narration", "content": "Just saying." },
    { "type": "narration", "content": "Larry stared at the screen. The cursor blinked in the empty text box. He had about six different things typed and deleted." },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "aye tryouts in two weeks btw. you should pull up" },
    { "type": "message", "platform": "AIM", "sender": "LJ_Jenkins05", "recipient": "JMoss_WR1", "content": "for football?" },
    { "type": "message", "platform": "AIM", "sender": "JMoss_WR1", "recipient": "LJ_Jenkins05", "content": "yeah lol why not" },
    { "type": "narration", "content": "Larry closed the chat window." },
    { "type": "narration", "content": "He opened Jonathan's MySpace profile. 847 friends. Top 8 full of people Larry didn't recognize yet — people Jonathan had already collected on the first day of school." },
    { "type": "narration", "content": "Larry's friend count was 4. One of them was Tom." },
    { "type": "narration", "content": "He sat there for a long time looking at nothing." },
    { "type": "narration", "content": "Two weeks until tryouts." }
  ]
